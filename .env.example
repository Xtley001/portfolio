# ── Admin Auth ────────────────────────────────────────────────────
# Pick any strong password. This is what you type at /admin
ADMIN_PASSWORD=your_strong_password_here

# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_32_char_minimum_secret_string_here

# ── GitHub (for publishing projects from admin) ───────────────────
# Create at: github.com/settings/tokens/new
# Permissions needed: repo → Contents (read + write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=Xtley001
GITHUB_REPO=portfolio   # whatever you named your portfolio repo

# ── Cloudinary (free image hosting) ──────────────────────────────
# Sign up free at: cloudinary.com
# Cloud name: find in Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Create an Upload Preset at: Settings → Upload → Upload Presets
# Set it to "Unsigned" so uploads work from the browser
CLOUDINARY_UPLOAD_PRESET=portfolio_unsigned
